PROJECT_NAME=Task Flow API 2
API_VERSION=1.0.0
API_V1_STR=/api/v1

# PostgreSQL (change together: POSTGRES_*, DATABASE_URL, ALEMBIC_DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskflow

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/taskflow
ALEMBIC_DATABASE_URL=postgresql://postgres:postgres@db:5432/taskflow
TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db

SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin
ADMIN_FULL_NAME=System Admin

REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=120
DEFAULT_RATE_LIMIT=100/minute
MEDIA_ROOT=./media
MEDIA_URL_PREFIX=/media
MAX_IMAGE_UPLOAD_SIZE_MB=5

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173
